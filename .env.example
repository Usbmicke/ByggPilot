# ByggPilot miljövariabler för Vite/Firebase
VITE_FIREBASE_API_KEY=din_api_nyckel
VITE_FIREBASE_AUTH_DOMAIN=din_auth_domain
VITE_FIREBASE_PROJECT_ID=din_project_id
VITE_FIREBASE_STORAGE_BUCKET=din_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=din_messaging_sender_id
VITE_FIREBASE_APP_ID=din_app_id

# AI API Keys
GOOGLE_API_KEY=your_google_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_optional

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual API keys
# 3. Never commit the .env file to version control
